{
  "name": "ai-shorts-studio-v0-4-0",
  "version": "0.4.0",
  "private": true,
  "description": "AI Shorts Studio v0.4.0 - local shorts recommendation with draggable waveform range editing, thumbnail templates, batch export, captions and project JSON save/load",
  "scripts": {
    "serve": "python3 -m http.server 8080",
    "check": "node qa/run_all_checks.js",
    "package:clean": "bash tools/create-release-zip.sh"
  },
  "qaChecks": [
    "node --check src/config/app-runtime-config.js",
    "node --check src/state/app-state.js",
    "node --check src/utils/core-utils.js",
    "node --check src/analysis/audio-feature-extractor.js",
    "node --check src/analysis/video-motion-analyzer.js",
    "node --check src/recommendation/shorts-recommendation-engine.js",
    "node --check src/caption/caption-service.js",
    "node --check src/project/project-service.js",
    "node --check src/render/vertical-renderer.js",
    "node --check src/download/download-service.js",
    "node --check src/ui/waveform-view.js",
    "node --check src/ui/timeline-view.js",
    "node --check src/ui/ux-controls.js",
    "node --check src/ui/range-drag-controls.js",
    "node --check src/security/site-guards.js",
    "node --check src/boot/runtime-health.js",
    "node --check src/workers/highlight-analysis.worker.js",
    "node --check sw.js",
    "node --check src/app.js",
    "node qa/no_duplicate_functions_smoke.js",
    "node qa/no_external_dependency_smoke.js",
    "node qa/html_anchor_smoke.js",
    "node qa/uiux_anchor_smoke.js",
    "node qa/advanced_editor_smoke.js",
    "node qa/recommendation_engine_smoke.js",
    "node qa/render_capability_smoke.js",
    "node qa/docs_handoff_smoke.js",
    "node qa/caption_service_smoke.js",
    "node qa/project_service_smoke.js"
  ]
}
